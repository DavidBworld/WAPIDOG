# Autoriser la réécriture d'URL sur les sous-pages et désactiver MultiViews pour Hostinger
Options +FollowSymLinks -MultiViews

RewriteEngine On
RewriteBase /

# 1. Rediriger proprement index.php vers la racine / (évite le duplicate content)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.php\ HTTP/
RewriteRule ^index\.php$ https://wapidogs-family.fr/ [R=301,L]

# 2. Réécritures transparentes spécifiques pour nos silos SEO complexes
RewriteRule ^education-comportement$ education.php [L,QSA]
RewriteRule ^mushing-activites$ mushing.php [L,QSA]

# 3. Réécritures transparentes spécifiques pour les 3 articles de blog séparés
RewriteRule ^blog-elevage$ blog-elevage.php [L,QSA]
RewriteRule ^blog-education$ blog-education.php [L,QSA]
RewriteRule ^blog-mushing$ blog-mushing.php [L,QSA]

# 4. Supprimer l'extension .php de l'URL pour TOUTES les autres pages physiques existantes (palmares, contact, blog, mentions, etc.)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]
